{
  "name": "0xstack",
  "version": "0.1.7",
  "private": false,
  "type": "module",
  "bin": {
    "0xstack": "dist/index.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xmilord/0xstack.git"
  },
  "homepage": "https://github.com/0xmilord/0xstack",
  "bugs": {
    "url": "https://github.com/0xmilord/0xstack/issues"
  },
  "keywords": [
    "cli",
    "nextjs",
    "starter",
    "supabase",
    "drizzle",
    "better-auth"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "cac": "6.7.14",
    "chalk": "5.6.2",
    "execa": "9.6.0",
    "jiti": "2.5.1",
    "ora": "8.2.0",
    "prompts": "2.4.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "@types/prompts": "2.4.9",
    "@vitest/coverage-v8": "3.2.4",
    "tsup": "8.5.0",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}